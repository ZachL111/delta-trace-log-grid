{
  "repo": "delta-trace-log-grid",
  "language": "Scala",
  "category": "Observability",
  "goal": "Package a Scala local lab for log analysis with round-trip fixtures, lossless normalization checks, and documented operating limits.",
  "review_model": {
    "terms": [
      "span volume",
      "latency skew",
      "signal loss",
      "incident shape"
